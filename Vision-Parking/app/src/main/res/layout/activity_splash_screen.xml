<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/splash_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="100dp">

        <!-- Logo with P design -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/visionpark_logo"
            android:contentDescription="VisionPark Logo" />

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VisionPark"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ticket-less, Cash-less, Stress-free"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- Get Started Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGetStarted"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="Get Started"
        android:textAllCaps="false"
        android:textColor="@color/splash_green"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        android:backgroundTint="@color/white"
        android:layout_marginBottom="60dp"
        android:fontFamily="sans-serif" />

</LinearLayout>