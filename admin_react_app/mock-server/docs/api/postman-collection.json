{
  "info": {
    "name": "Parking Admin Mock Server API",
    "description": "Comprehensive API collection for testing the Parking Admin Dashboard Mock Server",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin@parking.com",
      "type": "string"
    },
    {
      "key": "admin_password",
      "value": "Admin@123",
      "type": "string"
    },
    {
      "key": "superadmin_email",
      "value": "superadmin@parking.com",
      "type": "string"
    },
    {
      "key": "superadmin_password",
      "value": "SuperAdmin@123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login as Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response.access_token);",
                  "    pm.test('Login successful', function () {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.access_token).to.be.a('string');",
                  "        pm.expect(response.user.role).to.eql('super_admin');",
                  "    });",
                  "} else {",
                  "    pm.test('Login failed', function () {",
                  "        pm.expect(pm.response.code).to.be.oneOf([400, 401, 403]);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_email\": \"{{superadmin_email}}\",\n  \"user_password\": \"{{superadmin_password}}\",\n  \"role\": \"super_admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response.access_token);",
                  "    pm.test('Login successful', function () {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.access_token).to.be.a('string');",
                  "        pm.expect(response.user.role).to.eql('admin');",
                  "    });",
                  "} else {",
                  "    pm.test('Login failed', function () {",
                  "        pm.expect(pm.response.code).to.be.oneOf([400, 401, 403]);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_email\": \"{{admin_email}}\",\n  \"user_password\": \"{{admin_password}}\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Profile retrieved successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('user_id');",
                  "    pm.expect(response).to.have.property('role');",
                  "    pm.expect(response).to.have.property('user_email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Session Management",
      "item": [
        {
          "name": "Get All Session Details (Super Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Session details retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/sessions/details/all?page=1&limit=20&status=all",
              "host": ["{{base_url}}"],
              "path": ["admin", "all_session", "details", ""],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "all"
                }
              ]
            }
          }
        },
        {
          "name": "Get Admin Session Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin session details retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/session/details/2?status=active",
              "host": ["{{base_url}}"],
              "path": ["admin", "session", "details", "2"],
              "query": [
                {
                  "key": "status",
                  "value": "active"
                }
              ]
            }
          }
        },
        {
          "name": "Vehicle Check-in",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Vehicle checked in successfully', function () {",
                  "    if (pm.response.code === 201) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.ticket_id).to.be.a('string');",
                  "        pm.expect(response.session).to.be.an('object');",
                  "        pm.collectionVariables.set('test_ticket_id', response.ticket_id);",
                  "    } else if (pm.response.code === 409) {",
                  "        pm.expect(pm.response.json().error).to.include('occupied');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle_reg_no\": \"DL01TEST123\",\n  \"slot_id\": 25,\n  \"lot_id\": 1,\n  \"vehicle_type\": \"car\",\n  \"notes\": \"Test check-in from Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/session/checkin",
              "host": ["{{base_url}}"],
              "path": ["admin", "session", "checkin"]
            }
          }
        },
        {
          "name": "Vehicle Check-out",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Vehicle checked out successfully', function () {",
                  "    if (pm.response.code === 200) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.session).to.be.an('object');",
                  "        pm.expect(response.payment).to.be.an('object');",
                  "    } else if (pm.response.code === 404) {",
                  "        pm.expect(pm.response.json().error).to.include('not found');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket_id\": \"{{test_ticket_id}}\",\n  \"payment_method\": \"digital\",\n  \"amount_paid\": 50.0,\n  \"notes\": \"Test check-out from Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/session/checkout",
              "host": ["{{base_url}}"],
              "path": ["admin", "session", "checkout"]
            }
          }
        }
      ]
    },
    {
      "name": "Financial Management",
      "item": [
        {
          "name": "Get Total Due Amounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Total due amounts retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.expect(response.opening_balance).to.be.a('number');",
                  "    pm.expect(response.today_collection).to.be.a('number');",
                  "    pm.expect(response.total_due).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/total_due?admin_id=2&date=2025-01-21",
              "host": ["{{base_url}}"],
              "path": ["admin", "total_due"],
              "query": [
                {
                  "key": "admin_id",
                  "value": "2"
                },
                {
                  "key": "date",
                  "value": "2025-01-21"
                }
              ]
            }
          }
        },
        {
          "name": "Get Daily Closure Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Closure data retrieved', function () {",
                  "    if (pm.response.code === 200) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.closure).to.be.an('object');",
                  "    } else if (pm.response.code === 404) {",
                  "        pm.expect(pm.response.json().error).to.include('not found');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/closure?date=2025-01-21&admin_id=2",
              "host": ["{{base_url}}"],
              "path": ["admin", "closure"],
              "query": [
                {
                  "key": "date",
                  "value": "2025-01-21"
                },
                {
                  "key": "admin_id",
                  "value": "2"
                }
              ]
            }
          }
        },
        {
          "name": "Create Closure Record",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Closure record created', function () {",
                  "    if (pm.response.code === 201) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.closure).to.be.an('object');",
                  "        pm.collectionVariables.set('test_closure_id', response.closure.closure_id);",
                  "    } else if (pm.response.code === 409) {",
                  "        pm.expect(pm.response.json().error).to.include('already exists');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-01-21\",\n  \"admin_id\": 2,\n  \"parkinglot_ids\": [1, 2],\n  \"opening_balance\": 1000.0,\n  \"today_collection\": 3500.0,\n  \"amount_paid\": 4000.0,\n  \"notes\": \"Test closure from Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/closure",
              "host": ["{{base_url}}"],
              "path": ["admin", "closure"]
            }
          }
        },
        {
          "name": "Finalize Closure",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Closure finalized successfully', function () {",
                  "    if (pm.response.code === 200) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.closure).to.be.an('object');",
                  "    } else if (pm.response.code === 404) {",
                  "        pm.expect(pm.response.json().error).to.include('not found');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"closure_id\": \"{{test_closure_id}}\",\n  \"amount_paid\": 4000.0,\n  \"payment_method\": \"digital\",\n  \"notes\": \"Finalized from Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/finalize_closure",
              "host": ["{{base_url}}"],
              "path": ["admin", "finalize_closure"]
            }
          }
        }
      ]
    },
    {
      "name": "Health & Monitoring",
      "item": [
        {
          "name": "Basic Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health check successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.expect(response.status).to.be.oneOf(['healthy', 'degraded']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Detailed Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Detailed health check successful', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status).to.be.oneOf(['healthy', 'degraded', 'unhealthy']);",
                  "    pm.except(response.checks).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/detailed",
              "host": ["{{base_url}}"],
              "path": ["health", "detailed"]
            }
          }
        },
        {
          "name": "Get Metrics (JSON)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Metrics retrieved successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.expect(response.requests).to.be.an('object');",
                  "    pm.expect(response.system).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/metrics",
              "host": ["{{base_url}}"],
              "path": ["metrics"]
            }
          }
        },
        {
          "name": "Get Metrics (Prometheus)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Prometheus metrics retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/plain');",
                  "    pm.expect(pm.response.text()).to.include('# HELP');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/metrics?format=prometheus",
              "host": ["{{base_url}}"],
              "path": ["metrics"],
              "query": [
                {
                  "key": "format",
                  "value": "prometheus"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "General",
      "item": [
        {
          "name": "Get API Information",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API information retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.message).to.include('Parking Admin');",
                  "    pm.expect(response.version).to.be.a('string');",
                  "    pm.expect(response.availableRoutes).to.be.an('object');",
                  "});"
