# Mock Server Environment Configuration Template
# Copy this file to .env and update values as needed

# Application Environment
NODE_ENV=development
PORT=3001
HOST=localhost

# React App URL for CORS (update for your React app)
REACT_APP_URL=http://localhost:5173

# JWT Configuration (CHANGE SECRET IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# Logging Configuration
LOG_LEVEL=info
ENABLE_PAYLOAD_LOGGING=false

# Mock Data Configuration
GENERATE_MOCK_DATA=true

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Production Environment Example:
# NODE_ENV=production
# PORT=3001
# HOST=0.0.0.0
# REACT_APP_URL=https://your-production-domain.com
# JWT_SECRET=your-production-secret-key
# LOG_LEVEL=warn
# ENABLE_PAYLOAD_LOGGING=false